-- Grow a Crypto Farm Hub

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local root = char:WaitForChild("HumanoidRootPart")
local humanoid = char:WaitForChild("Humanoid")

-- STATES
local AutoSell=false
local AutoBuy=false
local AutoPlace=false
local AutoCollect=false
local AutoUpgrade=false
local Speed=false

-- ANTI AFK
player.Idled:Connect(function()
VirtualUser:Button2Down(Vector2.new(),workspace.CurrentCamera.CFrame)
task.wait(1)
VirtualUser:Button2Up(Vector2.new(),workspace.CurrentCamera.CFrame)
end)

-- GUI
local gui=Instance.new("ScreenGui",game.CoreGui)

local main=Instance.new("Frame",gui)
main.Size=UDim2.new(0,300,0,340)
main.Position=UDim2.new(0,20,0,20)
main.BackgroundColor3=Color3.fromRGB(18,18,28)
main.Active=true
main.Draggable=true
Instance.new("UICorner",main)

local title=Instance.new("TextLabel",main)
title.Size=UDim2.new(1,0,0,35)
title.Text="Crypto Farm Hub"
title.TextColor3=Color3.fromRGB(0,255,180)
title.BackgroundTransparency=1
title.Font=Enum.Font.GothamBold

-- OPEN BUTTON
local open=Instance.new("TextButton",gui)
open.Size=UDim2.new(0,70,0,35)
open.Position=UDim2.new(0,20,0,20)
open.Text="OPEN"
open.Visible=false

local hide=Instance.new("TextButton",main)
hide.Size=UDim2.new(0,40,0,25)
hide.Position=UDim2.new(1,-45,0,5)
hide.Text="-"

hide.MouseButton1Click:Connect(function()
main.Visible=false
open.Visible=true
end)

open.MouseButton1Click:Connect(function()
main.Visible=true
open.Visible=false
end)

-- TOGGLE FUNCTION
local function Toggle(name,y,callback)

local btn=Instance.new("TextButton",main)
btn.Size=UDim2.new(0,250,0,35)
btn.Position=UDim2.new(0,25,0,y)
btn.Text=name
btn.Font=Enum.Font.GothamBold
btn.TextSize=14
btn.TextColor3=Color3.new(1,1,1)
btn.BackgroundColor3=Color3.fromRGB(40,40,55)
Instance.new("UICorner",btn)

local indicator=Instance.new("Frame",btn)
indicator.Size=UDim2.new(0,14,0,14)
indicator.Position=UDim2.new(1,-20,0.5,-7)
indicator.BackgroundColor3=Color3.fromRGB(200,0,0)
Instance.new("UICorner",indicator)

local state=false

btn.MouseButton1Click:Connect(function()

state=not state

indicator.BackgroundColor3=
state and Color3.fromRGB(0,255,120)
or Color3.fromRGB(200,0,0)

callback(state)

end)

end

-- BUTTONS
Toggle("Auto Sell Crypto",50,function(v)AutoSell=v end)
Toggle("Auto Buy Best Computer",90,function(v)AutoBuy=v end)
Toggle("Auto Place Computers",130,function(v)AutoPlace=v end)
Toggle("Auto Collect Mining",170,function(v)AutoCollect=v end)
Toggle("Auto Upgrade Computers",210,function(v)AutoUpgrade=v end)
Toggle("Speed Boost",250,function(v)Speed=v end)

-- SPEED
RunService.RenderStepped:Connect(function()

if Speed then
humanoid.WalkSpeed=35
else
humanoid.WalkSpeed=16
end

end)

-- AUTO COLLECT
task.spawn(function()

while true do
task.wait(0.3)

if AutoCollect then

for _,v in pairs(workspace:GetDescendants()) do

if v.Name:lower():find("miner") then

root.CFrame=v.CFrame+Vector3.new(0,2,0)

end

end

end

end

end)

-- AUTO SELL
task.spawn(function()

while true do
task.wait(2)

if AutoSell then

for _,v in pairs(workspace:GetDescendants()) do

if v.Name:lower():find("sell") then

root.CFrame=v.CFrame+Vector3.new(0,3,0)

end

end

end

end

end)

-- AUTO BUY COMPUTER
task.spawn(function()

while true do
task.wait(3)

if AutoBuy then

for _,v in pairs(workspace:GetDescendants()) do

if v.Name:lower():find("computer") then

root.CFrame=v.CFrame+Vector3.new(0,3,0)

end

end

end

end

end)
